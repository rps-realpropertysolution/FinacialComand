# Variáveis de ambiente — RPS Financial Command
# Copie para `.env` (local) e configure as MESMAS no painel da Vercel
# (Project → Settings → Environment Variables).
#
# A "publishable/anon key" do Supabase é pública por design (vai no bundle do
# front e é protegida por RLS) — não é um segredo de servidor.
VITE_SUPABASE_URL="https://SEU_PROJETO.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key"
VITE_SUPABASE_PROJECT_ID="seu_project_id"
